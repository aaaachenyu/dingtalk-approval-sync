# Server
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example.com
LOG_LEVEL=info

# DingTalk app credentials
DINGTALK_APP_KEY=dingxxxxxxxxxxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxx
DINGTALK_PROCESS_CODE=PROC-xxxxxxxxxxxxxxxx
# Optional: multiple approval process codes, comma-separated. If set, this overrides DINGTALK_PROCESS_CODE for polling/backfill.
# DINGTALK_PROCESS_CODES=PROC-xxxxxxxxxxxxxxxx,PROC-yyyyyyyyyyyyyyyy

# DingTalk HTTP event callback.
# In DingTalk Open Platform, subscribe to:
# /v1.0/event/bpms_instance_change/processCode/{YOUR_PROCESS_CODE}/type/finish
DINGTALK_CALLBACK_TOKEN=your_callback_token_3_to_32_chars
DINGTALK_CALLBACK_AES_KEY=your_43_character_encoding_aes_key
# For app-level event subscription this is usually AppKey; if validation fails, try CorpId.
# Leave unset to default to DINGTALK_APP_KEY.
# DINGTALK_CALLBACK_OWNER_KEY=dingxxxxxxxxxxxxxxxx
# Only for local plaintext tests, never enable in production.
ALLOW_PLAINTEXT_CALLBACK=false

# Polling fallback
POLL_ENABLED=true
POLL_CRON=*/10 * * * *
POLL_LOOKBACK_MINUTES=1440
DINGTALK_POLL_STATUSES=COMPLETED

# Translation
TRANSLATE_PURPOSE_TO_CHINESE=true

# Google Sheets
GOOGLE_SHEET_ID=1abcYourSpreadsheetId
GOOGLE_SHEET_RANGE=Approvals!A:K
# Use one of the following two options:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Field names in your DingTalk approval form.
# Multiple names are allowed, separated by comma. Matching is case-insensitive.
FIELD_PAYMENT_AMOUNT=付款金额,金额,支付金额,工资金额,实付金额,amount,total,importe,monto,monto total
FIELD_PAYEE=付款对象,收款方,供应商,客户,proveedor,supplier,vendor
FIELD_PURPOSE=付款用途,用途,付款事由,motivo de pago,payment purpose,purpose
FIELD_REMARK=备注,说明
FIELD_ATTACHMENTS=附件,付款附件,上传附件
